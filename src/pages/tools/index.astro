---
/*
 * /tools/ — index of all tools, presented as a contact-sheet film-strip
 * mirroring the home page but without the search-pin header. Used as a
 * canonical SEO landing page for "all image tools".
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import { tools } from '~/lib/toolMeta'
import {
  Minimize2,
  Maximize2,
  Crop,
  ArrowRightLeft,
  ImageIcon,
  Paintbrush,
  Sparkles,
  Eraser,
  Droplets,
  Laugh,
  RotateCw,
  Code,
  ScanFace,
} from 'lucide-react'

const iconMap: Record<string, typeof Minimize2> = {
  Minimize2,
  Maximize2,
  Crop,
  ArrowRightLeft,
  ImageIcon,
  Paintbrush,
  Sparkles,
  Eraser,
  Droplets,
  Laugh,
  RotateCw,
  Code,
  ScanFace,
}
---

<BaseLayout
  title={`All ${tools.length} tools — image-tools`}
  description={`Browse all ${tools.length} client-side image tools. Compress, resize, crop, convert, watermark, upscale, remove backgrounds, blur faces, generate memes, render HTML.`}
>
  <header class="spine page-head">
    <p class="eyebrow"><a href="/">image-tools</a> / tools</p>
    <h1>All tools</h1>
    <p class="lede">
      {tools.length} tools — pick one. Every tool processes images locally in
      your browser; nothing leaves your device.
    </p>
  </header>

  <section class="spine grid-section">
    <ul class="tool-strip">
      {tools.map((t) => {
        const Icon = iconMap[t.icon.name]
        return (
          <li>
            <a href={t.href} class="cell">
              <span class="glyph" aria-hidden="true">
                {Icon && <Icon size={28} strokeWidth={1.25} />}
              </span>
              <span class="label">{t.name.toLowerCase()}</span>
              <span class="desc">{t.description}</span>
            </a>
          </li>
        )
      })}
    </ul>
  </section>
</BaseLayout>

<style>
  .grid-section {
    padding-block: 2rem 4rem;
  }
  .tool-strip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
  }
  .cell {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1rem 1.25rem;
    background: var(--ink-2);
    color: var(--fg);
    text-decoration: none;
    transition: background 120ms ease;
    min-height: 110px;
  }
  .cell:hover {
    background: var(--phosphor);
    color: var(--ink);
  }
  .glyph {
    color: color-mix(in oklab, var(--paper) 80%, var(--ink));
    line-height: 0;
    transition: color 120ms ease;
    margin-bottom: 0.25rem;
  }
  .cell:hover .glyph {
    color: var(--ink);
  }
  .label {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14px;
  }
  .desc {
    color: var(--fg-mute);
    font-size: 12px;
    line-height: 1.4;
    transition: color 120ms ease;
  }
  .cell:hover .desc {
    color: var(--ink);
  }
  .cell:focus-visible {
    outline: 2px solid var(--phosphor);
    outline-offset: -3px;
  }
</style>
