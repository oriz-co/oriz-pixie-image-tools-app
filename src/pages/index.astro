---
/*
 * Home — contact-sheet film-strip per design-briefs/oriz-image-tools.md §3.
 *
 *   - Search field pinned top-centre, autofocused on load. Cycling
 *     placeholder. ⌘K refocuses it from anywhere.
 *   - 13-cell film-strip grid (5 wide × 3 rows), gap 1px filled by --line
 *     so cells share hairlines.
 *   - Each cell: 180×180, --ink-2 fill, mono glyph 32px in --paper at 80%,
 *     tool name beneath in Space Grotesk 14/500. Hover: cell flips to
 *     --phosphor fill, glyph + label go --ink.
 *   - Status bar bottom: "13 tools · 0 bytes uploaded · runs locally"
 *   - Footer-level histogram strip pulses on a synthetic curve until a real
 *     bitmap exists in sessionStorage.
 *
 * NO hero, NO marketing copy, NO feature cards, NO emoji, NO mascots.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import RGBHistogram from '~/components/RGBHistogram'
import { tools } from '~/lib/toolMeta'
import {
  Minimize2,
  Maximize2,
  Crop,
  ArrowRightLeft,
  ImageIcon,
  Paintbrush,
  Sparkles,
  Eraser,
  Droplets,
  Laugh,
  RotateCw,
  Code,
  ScanFace,
} from 'lucide-react'

// Map tool icon name (string) → component for SSR.
const iconMap: Record<string, typeof Minimize2> = {
  Minimize2,
  Maximize2,
  Crop,
  ArrowRightLeft,
  ImageIcon,
  Paintbrush,
  Sparkles,
  Eraser,
  Droplets,
  Laugh,
  RotateCw,
  Code,
  ScanFace,
}

const toolCount = tools.length

// Build a search-blob per tool so the client-side filter works on name +
// keywords + description. Embedded as a data attribute, not a JSON island.
const cells = tools.map((t) => ({
  ...t,
  searchBlob: [t.name, t.description, ...t.keywords].join(' ').toLowerCase(),
}))
---

<BaseLayout
  title="oriz · image-tools — 13 tools that run in your browser"
  description="Browser darkroom. 13 client-side image tools. Compress, resize, crop, convert, watermark, upscale, remove backgrounds, blur faces, generate memes, render HTML. Zero uploads."
  bareFooter={true}
>
  <section class="contact-sheet">
    <header class="search-row">
      <label for="tool-search" class="sr-only">Filter tools</label>
      <input
        id="tool-search"
        type="search"
        autocomplete="off"
        autofocus
        spellcheck="false"
        placeholder="compress · resize · remove-bg · …"
        class="search"
        data-search
      />
      <span class="kbd-hint mono" aria-hidden="true">⌘K</span>
    </header>

    <ul class="strip" data-strip>
      {cells.map((t) => {
        const Icon = iconMap[t.icon.name]
        return (
          <li class="cell" data-cell data-blob={t.searchBlob}>
            <a href={t.href} class="cell-link" aria-label={`${t.name} — ${t.description}`}>
              <span class="glyph" aria-hidden="true">
                {Icon && <Icon size={32} strokeWidth={1.25} />}
              </span>
              <span class="label">{t.name.toLowerCase()}</span>
              <span class="hover-desc mono">{t.description}</span>
            </a>
          </li>
        )
      })}
    </ul>

    <RGBHistogram client:load className="home-strip" height={64} label="Live RGB histogram" />

    <p class="status mono">
      <span data-status-count>{toolCount}</span>
      <span> tools · 0 bytes uploaded · runs locally</span>
    </p>
  </section>
</BaseLayout>

<style>
  .contact-sheet {
    /* Single-viewport contact sheet — header(56) + footer(32) reserved.
       Use min-height not height so on tall screens we still avoid scroll,
       and on short screens the grid scrolls naturally. */
    min-height: calc(100vh - 56px - 32px);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 24px 24px 0;
    gap: 24px;
  }

  .search-row {
    position: relative;
    width: 100%;
    max-width: 480px;
    display: flex;
    align-items: center;
  }
  .search {
    width: 100%;
    height: 44px;
    padding: 0 64px 0 16px;
    background: var(--ink-2);
    border: 1px solid var(--line);
    border-radius: 4px;
    color: var(--fg);
    font-family: var(--font-sans);
    font-size: 14px;
    outline: none;
    transition: border-color 120ms ease;
  }
  .search:focus {
    border-color: var(--phosphor);
  }
  .search::placeholder {
    color: var(--fg-mute);
  }
  .kbd-hint {
    position: absolute;
    right: 12px;
    color: var(--fg-soft);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    pointer-events: none;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /*
   * Film-strip grid. Per spec: 5 wide × 3 rows → 13 cells leaves the last
   * row half-empty; the brief reads "5 wide × 3 rows" but with 13 tools we
   * actually fit 5 × 3 with 2 empty trailing slots. Use auto-fit to be
   * resilient to count drift.
   *
   * Gap is 1px filled by --line so cells share hairlines like a real
   * contact sheet — done via outline, not gap, to avoid edge gaps.
   */
  .strip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, 180px);
    gap: 1px;
    background: var(--line); /* the hairline grid showing through */
    border: 1px solid var(--line);
  }
  @media (max-width: 1024px) {
    .strip {
      grid-template-columns: repeat(4, 180px);
    }
  }
  @media (max-width: 820px) {
    .strip {
      grid-template-columns: repeat(3, 160px);
    }
  }
  @media (max-width: 540px) {
    .strip {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .cell {
    background: var(--ink-2);
    aspect-ratio: 1 / 1;
    transition: background 120ms ease;
  }
  .cell-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    height: 100%;
    color: var(--fg);
    text-decoration: none;
    position: relative;
  }
  .glyph {
    color: color-mix(in oklab, var(--paper) 80%, var(--ink));
    line-height: 0;
    transition: color 120ms ease;
  }
  .label {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.005em;
    color: color-mix(in oklab, var(--paper) 80%, var(--ink));
    transition: color 120ms ease;
  }
  .hover-desc {
    position: absolute;
    bottom: 8px;
    left: 8px;
    right: 8px;
    text-align: center;
    font-size: 10px;
    line-height: 1.3;
    color: var(--ink);
    opacity: 0;
    transition: opacity 120ms ease;
    pointer-events: none;
  }

  .cell:hover {
    background: var(--phosphor);
  }
  .cell:hover .glyph,
  .cell:hover .label {
    color: var(--ink);
  }
  .cell:hover .hover-desc {
    opacity: 0.85;
  }
  .cell-link:focus-visible {
    outline: 2px solid var(--phosphor);
    outline-offset: -3px;
  }

  /* Cells filtered out by search go translucent + non-interactive but stay
     in the layout so the grid never re-flows. */
  .cell[data-hidden="true"] {
    opacity: 0.18;
    pointer-events: none;
  }

  .home-strip {
    width: 100%;
    max-width: none;
    height: 64px;
    margin-top: auto;
  }

  .status {
    width: 100%;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    color: color-mix(in oklab, var(--paper) 60%, var(--ink));
    font-family: var(--font-mono);
    font-size: 12px;
    margin: 0;
    border-top: 1px solid var(--line);
  }
</style>

<script>
  // Live filter — reads `data-blob` per cell, hides non-matches.
  // Also wires ⌘K / Ctrl+K to focus the search field from anywhere.
  const search = document.querySelector('[data-search]') as HTMLInputElement | null
  const cells = Array.from(document.querySelectorAll('[data-cell]')) as HTMLElement[]
  const status = document.querySelector('[data-status-count]') as HTMLElement | null
  const total = cells.length

  if (search && cells.length > 0) {
    const apply = (q: string) => {
      const needle = q.trim().toLowerCase()
      let visible = 0
      for (const cell of cells) {
        const blob = cell.dataset.blob ?? ''
        const match = needle === '' || blob.includes(needle)
        cell.dataset.hidden = match ? 'false' : 'true'
        if (match) visible++
      }
      if (status) status.textContent = String(visible || total)
    }
    search.addEventListener('input', () => apply(search.value))
  }

  // ⌘K / Ctrl+K to focus.
  window.addEventListener('keydown', (e: KeyboardEvent) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault()
      search?.focus()
      search?.select()
    }
  })

  // Cycling placeholder every 4s.
  const placeholders = [
    'compress · resize · remove-bg · …',
    'crop · rotate · upscale · …',
    'convert · watermark · meme · …',
    'blur-face · html-to-image · …',
  ]
  if (search) {
    let i = 0
    setInterval(() => {
      i = (i + 1) % placeholders.length
      search.placeholder = placeholders[i]
    }, 4000)
  }
</script>
