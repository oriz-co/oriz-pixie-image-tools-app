---
import BaseLayout from '~/layouts/BaseLayout.astro'

const sections = [
  { slug: 'privacy', label: 'Privacy policy', desc: 'What we collect, what we don\'t, your rights.' },
  { slug: 'terms', label: 'Terms of use', desc: 'The rules for using Image Tools.' },
  { slug: 'disclaimer', label: 'Disclaimer', desc: 'Not financial / medical / legal advice.' },
  { slug: 'cookies', label: 'Cookie policy', desc: 'What cookies and localStorage we set.' },
  { slug: 'grievance', label: 'Grievance officer', desc: 'Mandatory contact under IT Rules 2021.' },
]
---

<BaseLayout title="Legal — Image Tools" description="Privacy, terms, and grievance contact for image.oriz.in.">
  <header class="spine page-head">
    <p class="eyebrow"><a href="/">Image Tools</a> / Legal</p>
    <h1>Legal</h1>
  </header>

  <section class="spine section">
    <ul class="legal-list">
      {sections.map((s) => (
        <li>
          <a href={`/legal/${s.slug}/`} class="card">
            <h2>{s.label}</h2>
            <p>{s.desc}</p>
            <span class="arrow mono" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .section { padding-block: 2.5rem 4rem; }
  .legal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
  }
  .card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1rem 1.25rem;
    background: var(--ink-2);
    color: var(--fg);
    text-decoration: none;
    transition: background 120ms ease;
  }
  .card:hover {
    background: color-mix(in oklab, var(--phosphor) 8%, var(--ink-2));
  }
  .card h2 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.125rem;
    color: var(--fg);
  }
  .card p {
    color: var(--fg-mute);
    margin: 0;
    font-size: 0.875rem;
  }
  .arrow {
    color: var(--fg-soft);
    font-size: 1rem;
  }
  .card:hover .arrow {
    color: var(--phosphor);
  }
</style>

