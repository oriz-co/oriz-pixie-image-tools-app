---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { ContactForm } from '@chirag127/oriz-ui'

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<BaseLayout
  title="Contact — image-tools"
  description="Bug reports, feature requests, or anything else about image.oriz.in."
>
  <header class="spine page-head">
    <p class="eyebrow"><a href="/">image-tools</a> / contact</p>
    <h1>Contact</h1>
    <p class="lede">
      Bug, feature request, or feedback about a tool? The fastest way is email:
      <a href="mailto:whyiswhen@gmail.com"><strong>whyiswhen@gmail.com</strong></a>.
      For tracked issues, open one on
      <a href="https://github.com/chirag127/oriz-image-tools/issues">GitHub</a>.
    </p>
  </header>

  <section class="spine">
    <ContactForm
      client:load
      web3formsKey={web3formsKey}
      fromName="Image Tools contact form"
    />

    <p class="meta">
      For privacy questions or DMCA notices, see the
      <a href="/legal/grievance/">grievance officer</a> page (mandatory under IT Rules 2021).
    </p>
  </section>
</BaseLayout>

<style>
  .meta {
    font-size: 0.875rem;
    color: var(--fg-mute);
    margin-top: 2rem;
    padding-block: 2rem;
  }
  .meta a {
    color: var(--phosphor);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
</style>
