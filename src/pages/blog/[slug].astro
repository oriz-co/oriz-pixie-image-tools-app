---
import BaseLayout from '~/layouts/BaseLayout.astro'

export function getStaticPaths() {
  return [
    {
      params: { slug: 'compress-images-guide' },
      props: {
        title: 'How to compress images without losing quality',
        date: '2026-03-27',
        readTime: '6 min',
      },
    },
    {
      params: { slug: 'best-image-resizers-2026' },
      props: {
        title: 'Best free image resizers in 2026',
        date: '2026-03-27',
        readTime: '5 min',
      },
    },
    {
      params: { slug: 'remove-background-free' },
      props: {
        title: 'How to remove image backgrounds for free',
        date: '2026-03-27',
        readTime: '5 min',
      },
    },
    {
      params: { slug: 'heic-to-jpg-guide' },
      props: {
        title: 'Convert HEIC to JPG — step by step',
        date: '2026-03-27',
        readTime: '4 min',
      },
    },
    {
      params: { slug: 'image-upscaling-explained' },
      props: {
        title: 'What is image upscaling? AI explained simply',
        date: '2026-03-27',
        readTime: '5 min',
      },
    },
  ]
}

const { title, date, readTime } = Astro.props
const { slug } = Astro.params

const content: Record<string, string> = {
  'compress-images-guide': `
    <h2>Lossy vs lossless</h2>
    <p>JPG is lossy — it discards data the human eye is bad at noticing. PNG is lossless — every pixel is preserved, but files are larger. WebP and AVIF do both, with better compression than JPG at equal quality.</p>
    <h2>The right quality setting for the web</h2>
    <p>For photos: 70–80% JPG quality is the sweet spot. Below 60% you'll see blocking on flat regions; above 90% you're paying for bytes nobody can see.</p>
    <h2>Resize first, compress second</h2>
    <p>A 4000px image displayed at 800px wastes 95% of its pixels. Always resize to the actual rendered size before compressing — the savings are far bigger than any quality knob.</p>
    <h2>Modern formats</h2>
    <p>WebP saves 25–35% over JPG. AVIF saves another 20%. Both are supported in every current browser. Use them where you control the delivery (your own site); fall back to JPG/PNG when uploading to platforms that don't accept them.</p>
  `,
  'best-image-resizers-2026': `
    <h2>What "best" means here</h2>
    <p>Privacy-first, browser-only, no upload limits, no watermarks. Anything that uploads your photos to a server is automatically out.</p>
    <h2>Common sizes for 2026</h2>
    <ul>
      <li>Web hero — 1920×1080 or 1200×630</li>
      <li>Instagram square — 1080×1080</li>
      <li>Twitter / Facebook landscape — 1200×630</li>
      <li>Stories / Reels — 1080×1920</li>
      <li>YouTube thumbnail — 1280×720</li>
    </ul>
    <h2>What to look for</h2>
    <ol>
      <li>Aspect-ratio lock — prevents squishing</li>
      <li>Preset sizes — saves typing common dimensions</li>
      <li>Batch mode — resize 20 photos with one settings pass</li>
      <li>Interpolation control — bicubic for photos, nearest-neighbour for pixel art</li>
    </ol>
  `,
  'remove-background-free': `
    <h2>What background removal actually does</h2>
    <p>It produces a mask that separates subject from background, then composites the subject over a transparent layer. The output is a PNG (or sometimes WebP) with an alpha channel.</p>
    <h2>How browser-side AI works</h2>
    <p>An ONNX or TF.js model — usually a U-Net variant trained on millions of foreground/background pairs — runs in a Web Worker. Modern phones can do a 1MP image in 1–2 seconds; a desktop CPU does it in &lt;1.</p>
    <h2>Trade-offs vs Photoshop</h2>
    <p>Photoshop's Object Selection is more precise on hard edges (glasses, hair). The browser model is faster, free, and never sees your image. For most product-shot use cases the gap is small.</p>
    <h2>Avoid the soft-edge halo</h2>
    <p>Most models leave a 1–2 pixel feather of background around hair. Two fixes: matte against a similar background colour, or set the model's threshold higher and accept slightly tighter cuts.</p>
  `,
  'heic-to-jpg-guide': `
    <h2>What HEIC is</h2>
    <p>High Efficiency Image Container — Apple's default since iOS 11. It uses HEVC (H.265) compression internally, producing roughly half the file size of JPEG at the same quality.</p>
    <h2>Why convert</h2>
    <ul>
      <li>JPG works on every device and platform; HEIC doesn't</li>
      <li>Most websites and email clients reject HEIC uploads</li>
      <li>Older Windows versions need extra codecs to even view HEIC</li>
      <li>Many image editors don't support HEIC at all</li>
    </ul>
    <h2>The quality decision</h2>
    <p>HEIC at 50% looks roughly equal to JPG at 75% — so when converting, set JPG quality to 80–90% to preserve the original quality. Lower than that and you're losing detail twice.</p>
  `,
  'image-upscaling-explained': `
    <h2>Bicubic vs neural</h2>
    <p>Bicubic interpolation fills new pixels by averaging surrounding ones. It's fast and produces smooth, slightly soft enlargements. Neural upscaling (Real-ESRGAN, ESRGAN, SwinIR) hallucinates detail based on a learned prior — the results look sharper but the detail isn't real.</p>
    <h2>When upscaling helps</h2>
    <ul>
      <li>Old photos for print — neural fills in detail bicubic can't</li>
      <li>Small assets for high-DPI displays — 2× usually enough</li>
      <li>Recovery of overcompressed JPGs — neural removes blocking</li>
    </ul>
    <h2>When it doesn't</h2>
    <p>Faces and text are the failure modes. Real-ESRGAN smooths skin too aggressively (everyone looks 23) and turns small text into convincing-looking gibberish.</p>
  `,
}
---

<BaseLayout
  title={`${title} — image-tools`}
  description={`Notes on ${title.toLowerCase()}.`}
>
  <header class="spine page-head">
    <p class="eyebrow">
      <a href="/">image-tools</a> / <a href="/blog/">blog</a> / {slug}
    </p>
    <h1>{title}</h1>
    <p class="meta">
      <time>{date}</time> · {readTime} · Chirag Singhal
    </p>
  </header>

  <article class="spine prose" set:html={content[slug || ''] ?? ''} />

  <section class="spine try-row">
    <h2>Try the tools</h2>
    <ul>
      <li><a href="/tools/compress-image/" class="ghost mono">[ compress ]</a></li>
      <li><a href="/tools/resize-image/" class="ghost mono">[ resize ]</a></li>
      <li><a href="/tools/upscale-image/" class="ghost mono">[ upscale ]</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .try-row {
    padding-block: 2rem 4rem;
    border-top: 1px solid var(--line);
  }
  .try-row h2 {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--fg);
    margin: 0 0 1rem;
  }
  .try-row ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .ghost {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding-inline: 0.875rem;
    border: 1px solid var(--line);
    color: var(--fg);
    font-size: 12px;
    text-decoration: none;
    border-radius: 4px;
    transition: border-color 120ms, color 120ms;
  }
  .ghost:hover {
    border-color: var(--phosphor);
    color: var(--phosphor);
  }
</style>
