---
import BaseLayout from '~/layouts/BaseLayout.astro'

const posts = [
  {
    slug: 'compress-images-guide',
    title: 'How to compress images without losing quality',
    excerpt:
      'Lossy vs lossless, when to pick each, and the practical settings that keep web images sharp under 200KB.',
    date: '2026-03-27',
    readTime: '6 min',
  },
  {
    slug: 'best-image-resizers-2026',
    title: 'Best free image resizers in 2026',
    excerpt:
      'A short list of resizers that respect your privacy. What to look for, what to avoid, and the right pixel sizes for every platform.',
    date: '2026-03-27',
    readTime: '5 min',
  },
  {
    slug: 'remove-background-free',
    title: 'How to remove image backgrounds for free',
    excerpt:
      'Browser-side AI, the trade-offs vs Photoshop, and how to avoid the soft-edge halo on hair.',
    date: '2026-03-27',
    readTime: '5 min',
  },
  {
    slug: 'heic-to-jpg-guide',
    title: 'Convert HEIC to JPG — step by step',
    excerpt:
      'What HEIC actually is, why Windows still struggles with it, and the cleanest way to convert without quality loss.',
    date: '2026-03-27',
    readTime: '4 min',
  },
  {
    slug: 'image-upscaling-explained',
    title: 'What is image upscaling? AI explained simply',
    excerpt:
      'Bilinear vs Real-ESRGAN, why 4x looks plausible but isn\'t real detail, and when upscaling actually helps.',
    date: '2026-03-27',
    readTime: '5 min',
  },
]
---

<BaseLayout
  title="Blog — image-tools"
  description="Tutorials, guides, and tips for image processing. Compress, resize, convert, edit — without the marketing fluff."
>
  <header class="spine page-head">
    <p class="eyebrow"><a href="/">image-tools</a> / blog</p>
    <h1>Blog</h1>
    <p class="lede">
      Tutorials, guides, and tips for image processing. No upsells.
    </p>
  </header>

  <section class="spine posts">
    <ul>
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}/`} class="post-row">
            <span class="row-meta mono">
              <time>{post.date}</time>
              <span class="sep" aria-hidden="true">·</span>
              <span>{post.readTime}</span>
            </span>
            <span class="row-title">{post.title}</span>
            <span class="row-excerpt">{post.excerpt}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .posts {
    padding-block: 2rem 4rem;
  }
  .posts ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--line);
    border-block: 1px solid var(--line);
  }
  .post-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    grid-template-areas:
      'meta title'
      'meta excerpt';
    column-gap: 2rem;
    row-gap: 0.25rem;
    padding: 1.25rem 0.5rem;
    background: var(--ink);
    color: var(--fg);
    text-decoration: none;
    transition: background 120ms ease;
  }
  .post-row:hover {
    background: var(--ink-2);
  }
  .row-meta {
    grid-area: meta;
    color: var(--fg-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    align-self: start;
    padding-top: 0.25rem;
  }
  .sep {
    margin-inline: 0.375rem;
    color: var(--fg-soft);
  }
  .row-title {
    grid-area: title;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--fg);
    letter-spacing: -0.005em;
  }
  .post-row:hover .row-title {
    color: var(--phosphor);
  }
  .row-excerpt {
    grid-area: excerpt;
    color: var(--fg-mute);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  @media (max-width: 640px) {
    .post-row {
      grid-template-columns: 1fr;
      grid-template-areas:
        'meta'
        'title'
        'excerpt';
      row-gap: 0.375rem;
    }
  }
</style>
