---
import BaseLayout from '~/layouts/BaseLayout.astro'
import AccountPanel from '~/components/AccountPanel'
---

<BaseLayout
  title="Account — image-tools"
  description="Sign in to oriz. One account works across every oriz site."
  noindex={true}
>
  <header class="spine page-head">
    <p class="eyebrow"><a href="/">image-tools</a> / account</p>
    <h1>Account</h1>
    <p class="lede">
      Image Tools runs entirely in your browser and never needs an account.
      Signing in is optional — it only carries your preferences across the
      rest of the oriz family.
    </p>
  </header>

  <section class="spine">
    <AccountPanel client:load siteName="Image Tools" />
  </section>
</BaseLayout>
