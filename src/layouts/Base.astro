---
/*
 * Legacy Base.astro shim — forwards to BaseLayout. Kept so the old
 * tools/index, blog, privacy, and terms pages don't all need rewriting.
 * New pages should import BaseLayout directly.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'

interface Props {
  title: string
  description: string
  canonical?: string
  noindex?: boolean
  isToolPage?: boolean
}

const { title, description, canonical, noindex, isToolPage } = Astro.props
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  noindex={noindex}
  isToolPage={isToolPage}
>
  <slot />
</BaseLayout>
