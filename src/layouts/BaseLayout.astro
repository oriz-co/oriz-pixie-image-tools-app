---
/*
 * BaseLayout — single page shell for image.oriz.in v2.
 *
 * Two-zone layout:
 *   - Header (56px, no nav, no sidebar — see ./Header.astro)
 *   - <main> slot
 *   - Footer (32px filmstrip strip — see ./Footer.astro)
 *
 * NO oriz-ui Sidebar (the v2 brief drops the left rail entirely; the home
 * page contact-sheet IS the navigation, and tool pages have a back-breadcrumb).
 * NO theme picker, NO accent picker — the darkroom palette is fixed.
 *
 * Auth & contact islands are mounted on individual pages as needed (see
 * /account.astro, /contact.astro). They render unstyled markup with
 * data-oriz-* hooks; src/styles/oriz-ui-overrides.css paints them in the
 * phosphor palette.
 */
import '~/styles/global.css'
import '~/styles/oriz-ui-overrides.css'
import Footer from '@chirag127/astro-chrome/Footer.astro'
import Header from '@chirag127/astro-chrome/Header.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  /** Tool pages render the `[ ← all tools ]` breadcrumb instead of the ⌘K chip. */
  isToolPage?: boolean
  /** When true, suppress the chrome footer. Used by tool layouts that mount
   *  their own filmstrip-status row beneath a histogram strip. */
  bareFooter?: boolean
}

const {
  title = `${SITE_CONFIG.name} — ${SITE_CONFIG.tagline}`,
  description = SITE_CONFIG.description,
  canonical = `${SITE_CONFIG.origin}${Astro.url.pathname}`,
  noindex = false,
  jsonLd,
  isToolPage = false,
  bareFooter = false,
} = Astro.props

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT
const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
const ga4Id = import.meta.env.PUBLIC_GA4_ID
import '@chirag127/astro-shell/tokens.css'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chirag127" />
    <meta name="theme-color" content="#0E1116" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/*
      Type stack — Space Grotesk display + Inter body + JetBrains Mono numerals.
      Per design-briefs/oriz-image-tools.md §2 — Space Grotesk is the only
      Space Grotesk site in the family. Mono carries EXIF, hex, dimensions.
    */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    {
      jsonLd && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
        />
      )
    }

    {
      adsenseClient && (
        <script
          is:inline
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }

    {
      beaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${beaconToken}"}`}
        />
      )
    }

    {
      ga4Id && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}
          />
          <script
            is:inline
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','${ga4Id}');`}
          />
        </>
      )
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header isToolPage={isToolPage} />
    <main id="main"><slot /></main>
    {!bareFooter && <Footer />}
  </body>
</html>
